    task.wait()
    if Toggles.WallBangV2.Value then
        local currentTargetHitbox = getClosestToCenter()
        local pNames = {["CoreProjectile"]=true, ["Slingshot"]=true, ["Daggers"]=true, ["Bow"]=true, ["Paintball Gun"]=true, ["Bullet"]=true}
        if (pNames[v.Name] or v:IsA("BasePart")) and currentTargetHitbox and currentTargetHitbox:FindFirstChild("Head") then
            local targetHead = currentTargetHitbox.Head
            if targetHead and firetouchinterest and v:IsDescendantOf(workspace) then
                v.CFrame = targetHead.CFrame
                v.AssemblyLinearVelocity = Vector3.zero
                firetouchinterest(targetHead, v, 0)
                firetouchinterest(targetHead, v, 1)
            end
        end
    end
end)

