local ents = {}
local function scan()
    ents = {}
    for _, v in pairs(workspace:GetChildren()) do
        if v:FindFirstChildOfClass("Humanoid") then
            table.insert(ents, v)
        elseif v.Name == "HurtEffect" then
            for _, hv in pairs(v:GetChildren()) do
                if hv.ClassName ~= "Highlight" then
                    table.insert(ents, hv)
                end
            end
        end
    end
end

local function getClosestToCenter()
    local char = lp.Character
    if not char then return end
    
    scan()
    local best, dist = nil, Options.FOV.Value
    local cam = workspace.CurrentCamera
    local scr = cam.ViewportSize / 2
    
    for _, v in pairs(ents) do
        if v == char or v.Name == lp.Name then continue end
        local hrp = v:FindFirstChild("HumanoidRootPart")
        if not hrp then continue end
        
        local pos, vis = cam:WorldToViewportPoint(hrp.Position)
        if not vis then continue end
        
        local d = (Vector2.new(pos.X, pos.Y) - scr).Magnitude
        if d < dist then
            best = v
            dist = d
        end
    end
    return best
end

local old_ray = util.Raycast
util.Raycast = function(s, o, d, len, f, ft, viz)
    if Toggles.SilentAim.Value and len == 999 and len > 100 and f then
        local tgt = getClosestToCenter()
        if tgt and tgt:FindFirstChild("Head") then
            local hitpos = tgt.Head.Position
            
            return {
                Position = hitpos,
                Distance = (hitpos - o).Magnitude,
                Instance = tgt.Head,
                Material = tgt.Head.Material,
                Normal = Vector3.yAxis
            }
        end
    end
    return old_ray(s, o, d, len, f, ft, viz)
end

local function CreateESP(plr)
    local Box = Drawing.new("Square")
    Box.Thickness = 1
    Box.Filled = false
    local Name = Drawing.new("Text")
    Name.Size = 14
    Name.Center = true
    Name.Outline = true

    rs.RenderStepped:Connect(function()
        if Toggles.ESP_Master.Value and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") and plr ~= lp and plr.Character:FindFirstChild("Humanoid").Health > 0 then
            local hrp = plr.Character.HumanoidRootPart
            local pos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(hrp.Position)
            if onScreen then
                local sizeX = 1000 / pos.Z
                local sizeY = 1500 / pos.Z
                
                Box.Visible = Toggles.ESP_Box.Value
                Box.Size = Vector2.new(sizeX, sizeY)
                Box.Position = Vector2.new(pos.X - sizeX / 2, pos.Y - sizeY / 2)
                Box.Color = (plr.Team == lp.Team and Color3.new(0,1,0) or Color3.new(1,0,0))
                
                Name.Visible = Toggles.ESP_Name.Value
                Name.Text = string.format("%s [%d m]", plr.Name, math.floor((hrp.Position - lp.Character.HumanoidRootPart.Position).Magnitude))
                Name.Position = Vector2.new(pos.X, pos.Y - (sizeY / 2) - 20)
                Name.Color = Box.Color
            else Box.Visible = false Name.Visible = false end
        else Box.Visible = false Name.Visible = false end
    end)
end

for _, v in pairs(plrs:GetPlayers()) do CreateESP(v) end
plrs.PlayerAdded:Connect(CreateESP)

rs.RenderStepped:Connect(function()
    if lp.Character and lp.Character:FindFirstChild("HumanoidRootPart") then
        local char = lp.Character
        local hrp = char.HumanoidRootPart
        local hum = char:FindFirstChildOfClass("Humanoid")
        local cam = workspace.CurrentCamera

        if Toggles.Aimbot.Value and uis:IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
            local target = getClosestToCenter()
            if target and target:FindFirstChild("Head") then
                cam.CFrame = cam.CFrame:Lerp(CFrame.new(cam.CFrame.Position, target.Head.Position), 0.1)
            end
        end

        if Toggles.FlyToggle.Value then
            local moveDir = Vector3.zero
            if uis:IsKeyDown("W") then moveDir += cam.CFrame.LookVector end
            if uis:IsKeyDown("S") then moveDir -= cam.CFrame.LookVector end
            if uis:IsKeyDown("A") then moveDir -= cam.CFrame.RightVector end
            if uis:IsKeyDown("D") then moveDir += cam.CFrame.RightVector end
            hrp.Velocity = moveDir * Options.FlySlider.Value
        end

        if Toggles.SpinToggle.Value then
            local t = tick()
            hrp.CFrame *= CFrame.Angles(0, math.rad(50), 0)
            if hum then hum.PlatformStand = true end
            
            local neck = char:FindFirstChild("Head") and char.Head:FindFirstChild("Neck")
            if neck then neck.C0 = CFrame.new(0, 1 + math.sin(t*20)*0.5, 0) * CFrame.Angles(math.rad(t*900%360), math.rad(t*800%360), 0) end
            local waist = char:FindFirstChild("UpperTorso") and char.UpperTorso:FindFirstChild("Waist")
            if waist then waist.C0 = CFrame.new(0, 0.8 + math.sin(t*15)*0.7, 0) * CFrame.Angles(0, math.rad(t*1000%360), math.rad(math.sin(t*10)*40)) end
        else
            if hum and hum.PlatformStand then 
                hum.PlatformStand = false 
                local neck = char:FindFirstChild("Head") and char.Head:FindFirstChild("Neck")
                if neck then neck.C0 = CFrame.new(0, 1, 0) * CFrame.Angles(math.rad(-90), 0, math.rad(180)) end
                local waist = char:FindFirstChild("UpperTorso") and char.UpperTorso:FindFirstChild("Waist")
                if waist then waist.C0 = CFrame.new(0, 0.8, 0) end
            end
        end
        
        if tick() % 0.5 < 0.03 then
            for _, obj in pairs(workspace:GetChildren()) do
                if obj.Name == "_drop" and obj:IsA("BasePart") then
                    firetouchinterest(hrp, obj, 0)
                    firetouchinterest(hrp, obj, 1)
                end
            end
        end
    end
end)

-- 투사체 월뱅 시 무한루프 연타를 없애고 깔끔하게 단발성으로 1회 동기화하여 상대가 날아가는 버그 차단
