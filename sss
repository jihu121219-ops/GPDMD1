-- FOV 테두리 링용 Drawing 오브젝트 풀
local FOVSegments = 60
local FOVLines = {}
for i = 1, FOVSegments do
    local line = Drawing.new("Line")
    line.Thickness = 2.5
    line.Transparency = 1
    line.Visible = false
    table.insert(FOVLines, line)
end

-- 색상 보간 헬퍼 함수
local function lerpColor(c1, c2, c3, fraction)
    if fraction < 0.5 then
        return c1:Lerp(c2, fraction * 2)
    else
        return c2:Lerp(c3, (fraction - 0.5) * 2)
    end
end

-- 실시간 그래픽 및 실시간 컬러 인덱스 연산 스텝
rs.RenderStepped:Connect(function()
    local t = tick()
    local cam = workspace.CurrentCamera
    local center = cam.ViewportSize / 2

    -- 1. 커스텀 3색 기반 화면 오버레이 연산
    if Toggles.ScreenEffect.Value then
        EffectFrame.BackgroundTransparency = 1 - (Options.OverlayAlpha.Value / 100)
        local freq = Options.DepthFreq.Value / 10
        
        local baseCol1 = Options.OverlayColor1.Value
        local baseCol2 = Options.OverlayColor2.Value
        local baseCol3 = Options.OverlayColor3.Value
        
        local shift = (t * freq) % 1
        local col1 = lerpColor(baseCol1, baseCol2, baseCol3, shift)
        local col2 = lerpColor(baseCol2, baseCol3, baseCol1, shift)
        local col3 = lerpColor(baseCol3, baseCol1, baseCol2, shift)
        
        UIGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, col1),
            ColorSequenceKeypoint.new(0.5, col2),
            ColorSequenceKeypoint.new(1, col3)
        })
        UIGradient.Rotation = (t * 45) % 360
    else
        EffectFrame.BackgroundTransparency = 1
    end

    -- 2. FOV 테두리 및 내부 채우기 실시간 데이터 리스닝 갱신 완료
    local radius = Options.FOV.Value
    local speed = Options.FOVSpeed.Value
    
    local c1 = Options.FOVColor1.Value
    local c2 = Options.FOVColor2.Value
    local c3 = Options.FOVColor3.Value
    local angleOffset = t * speed

    -- [내부 그라데이션 채우기 컬러 동기화]
    if Toggles.FillFOV.Value then
        FOVFillFrame.Visible = true
        FOVFillFrame.Position = UDim2.fromOffset(center.X, center.Y)
        FOVFillFrame.Size = UDim2.fromOffset(radius * 2, radius * 2)
        FOVFillFrame.BackgroundTransparency = 1 - (Options.FOVFillAlpha.Value / 100)
        
        local shift = (t * (speed / 5)) % 1
        local col1 = lerpColor(c1, c2, c3, shift)
        local col2 = lerpColor(c2, c3, c1, shift)
        local col3 = lerpColor(c3, c1, c2, shift)

        FOVFillGradient.Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, col1),
            ColorSequenceKeypoint.new(0.5, col2),
            ColorSequenceKeypoint.new(1, col3)
        })
        FOVFillGradient.Rotation = (t * (speed * 10)) % 360
    else
        FOVFillFrame.Visible = false
    end

    -- [테두리 링 컬러 동기화]
    if Toggles.RainbowFOV.Value then
        for i = 1, FOVSegments do
            local line = FOVLines[i]
            local deg1 = ((i - 1) / FOVSegments) * 360 + angleOffset
            local deg2 = (i / FOVSegments) * 360 + angleOffset
            local rad1, rad2 = math.rad(deg1), math.rad(deg2)
            
            line.From = center + Vector2.new(math.cos(rad1), math.sin(rad1)) * radius
            line.To = center + Vector2.new(math.cos(rad2), math.sin(rad2)) * radius
            
            local fraction = (i / FOVSegments)
            line.Color = lerpColor(c1, c2, c3, fraction)
            line.Visible = true
        end
    else
        for _, line in pairs(FOVLines) do line.Visible = false end
    end
end)


